<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 300 500">
  <defs>
    <linearGradient id="frontGrad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#2a2a2a;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#1a1a1a;stop-opacity:1" />
    </linearGradient>
  </defs>
  
  <!-- Phone body -->
  <rect x="30" y="20" width="240" height="460" rx="35" fill="url(#frontGrad)" stroke="#666" stroke-width="2"/>
  
  <!-- Screen -->
  <rect x="45" y="40" width="210" height="420" rx="30" fill="#001a33"/>
  
  <!-- Dynamic Island -->
  <rect x="110" y="55" width="80" height="35" rx="17" fill="#000"/>
  <circle cx="135" cy="73" r="5" fill="#0099ff"/>
  <circle cx="155" cy="73" r="5" fill="#0099ff"/>
  
  <!-- Content display -->
  <g opacity="0.8">
    <rect x="60" y="120" width="180" height="6" rx="3" fill="#0099ff"/>
    <rect x="60" y="145" width="150" height="5" rx="2.5" fill="#00ccff"/>
    <rect x="60" y="165" width="170" height="5" rx="2.5" fill="#00ccff"/>
    
    <!-- Camera display -->
    <circle cx="150" cy="250" r="45" fill="none" stroke="#0099ff" stroke-width="1.5" opacity="0.6"/>
    
    <!-- Text -->
    <text x="150" y="350" font-size="14" fill="#0099ff" text-anchor="middle" font-weight="bold">Mặt Trước</text>
    <text x="150" y="375" font-size="11" fill="#666" text-anchor="middle">OLED ProMotion</text>
    <text x="150" y="390" font-size="11" fill="#666" text-anchor="middle">120Hz Display</text>
  </g>
</svg>