<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 300 500">
  <defs>
    <linearGradient id="sideGrad" x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" style="stop-color:#2a2a2a;stop-opacity:1" />
      <stop offset="50%" style="stop-color:#0099ff;stop-opacity:0.3" />
      <stop offset="100%" style="stop-color:#1a1a1a;stop-opacity:1" />
    </linearGradient>
  </defs>
  
  <!-- Perspective 3D frame -->
  <g transform="translate(150, 250)">
    <!-- Main body -->
    <rect x="-90" y="-180" width="180" height="360" fill="url(#sideGrad)" stroke="#666" stroke-width="2"/>
    
    <!-- Top edge -->
    <polyline points="-90,-180 -85,-165 85,-165 90,-180" fill="#1a1a1a" stroke="#555" stroke-width="1"/>
    
    <!-- Screen edge -->
    <rect x="-80" y="-170" width="160" height="12" fill="#0099ff" opacity="0.2" stroke="#0099ff" stroke-width="0.5"/>
    
    <!-- Button group 1 (top) -->
    <rect x="90" y="-110" width="10" height="22" rx="5" fill="#555" stroke="#666" stroke-width="1"/>
    
    <!-- Button group 2 (middle) -->
    <rect x="90" y="-70" width="10" height="22" rx="5" fill="#555" stroke="#666" stroke-width="1"/>
    <rect x="90" y="-35" width="10" height="22" rx="5" fill="#666" stroke="#777" stroke-width="1"/>
    
    <!-- Volume rocker -->
    <rect x="90" y="10" width="10" height="28" rx="5" fill="#555" stroke="#666" stroke-width="1"/>
    
    <!-- Speaker slot -->
    <g stroke="#666" stroke-width="1" opacity="0.7">
      <line x1="90" y1="80" x2="90" y2="120"/>
    </g>
    
    <!-- Bottom edge -->
    <polyline points="-90,180 -85,165 85,165 90,180" fill="#0a0a0a" stroke="#555" stroke-width="1"/>
    
    <!-- USB-C port -->
    <rect x="-18" y="180" width="36" height="10" fill="#333" stroke="#666" stroke-width="1" rx="2"/>
  </g>
  
  <!-- Text -->
  <g opacity="1">
    <text x="150" y="450" font-size="14" fill="#0099ff" text-anchor="middle" font-weight="bold">Cạnh Bên</text>
    <text x="150" y="475" font-size="11" fill="#666" text-anchor="middle">Khung Titanium Premium</text>
    <text x="150" y="490" font-size="11" fill="#666" text-anchor="middle">IPX8 Chống Nước</text>
  </g>
</svg>