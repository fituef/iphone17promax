<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 300 500">
  <defs>
    <linearGradient id="backGrad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#1a1a1a;stop-opacity:1" />
      <stop offset="50%" style="stop-color:#0f0f0f;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#050505;stop-opacity:1" />
    </linearGradient>
  </defs>
  
  <!-- Phone body -->
  <rect x="30" y="20" width="240" height="460" rx="35" fill="url(#backGrad)" stroke="#666" stroke-width="2"/>
  
  <!-- Camera module housing -->
  <g transform="translate(150, 130)">
    <!-- Module background -->
    <rect x="-70" y="-60" width="140" height="120" rx="18" fill="#0a0a0a" stroke="#333" stroke-width="1"/>
    
    <!-- Main camera - 200MP -->
    <circle cx="-35" cy="-20" r="28" fill="#000" stroke="#555" stroke-width="2"/>
    <circle cx="-35" cy="-20" r="24" fill="#0a0a0a"/>
    <circle cx="-35" cy="-20" r="18" fill="#050505"/>
    <circle cx="-35" cy="-20" r="12" fill="#001a33" opacity="0.6"/>
    <circle cx="-28" cy="-13" r="3" fill="#00ccff" opacity="0.8"/>
    
    <!-- Ultra wide camera -->
    <circle cx="0" cy="15" r="22" fill="#000" stroke="#555" stroke-width="2"/>
    <circle cx="0" cy="15" r="18" fill="#0a0a0a"/>
    <circle cx="0" cy="15" r="12" fill="#050505"/>
    
    <!-- Telephoto camera -->
    <circle cx="35" cy="-20" r="26" fill="#000" stroke="#555" stroke-width="2"/>
    <circle cx="35" cy="-20" r="22" fill="#0a0a0a"/>
    <circle cx="35" cy="-20" r="15" fill="#050505"/>
    
    <!-- Macro camera -->
    <circle cx="0" cy="-50" r="18" fill="#000" stroke="#555" stroke-width="2"/>
    <circle cx="0" cy="-50" r="14" fill="#0a0a0a"/>
    
    <!-- Flash -->
    <rect x="50" y="10" width="14" height="14" rx="3" fill="#222" stroke="#555" stroke-width="1"/>
    <rect x="52" y="12" width="10" height="10" fill="#333"/>
  </g>
  
  <!-- Apple logo area -->
  <circle cx="150" cy="320" r="12" fill="none" stroke="#666" stroke-width="1" opacity="0.5"/>
  
  <!-- Text -->
  <g opacity="1">
    <text x="150" y="410" font-size="14" fill="#0099ff" text-anchor="middle" font-weight="bold">Mặt Sau</text>
    <text x="150" y="435" font-size="11" fill="#666" text-anchor="middle">Camera 200MP Ultra</text>
    <text x="150" y="450" font-size="11" fill="#666" text-anchor="middle">4 Ống kính cao cấp</text>
  </g>
</svg>