<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 400 500">
  <defs>
    <linearGradient id="cameraBg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#0a0a0a;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#1a1a1a;stop-opacity:1" />
    </linearGradient>
  </defs>
  
  <rect width="400" height="500" fill="url(#cameraBg)"/>
  
  <!-- Default -->
  <text x="200" y="35" font-size="22" fill="#0099ff" text-anchor="middle" font-weight="bold">Camera Pro 200MP</text>
  <text x="200" y="60" font-size="13" fill="#666" text-anchor="middle">Advanced AI Technology</text>
  
  <!-- Main camera visualization -->
  <g transform="translate(200, 180)">
    <!-- Outer rings -->
    <circle cx="0" cy="0" r="90" fill="none" stroke="#0099ff" stroke-width="2" opacity="0.8"/>
    <circle cx="0" cy="0" r="70" fill="none" stroke="#0099ff" stroke-width="1" opacity="0.5"/>
    
    <!-- Middle rings with accent -->
    <circle cx="0" cy="0" r="50" fill="none" stroke="#ff6B6B" stroke-width="2" opacity="0.7"/>
    <circle cx="0" cy="0" r="40" fill="none" stroke="#ff6B6B" stroke-width="1" opacity="0.4"/>
    
    <!-- Inner rings -->
    <circle cx="0" cy="0" r="30" fill="none" stroke="#4ECDC4" stroke-width="2" opacity="0.6"/>
    <circle cx="0" cy="0" r="20" fill="none" stroke="#4ECDC4" stroke-width="1" opacity="0.3"/>
    
    <!-- Center sensor -->
    <circle cx="0" cy="0" r="12" fill="#0099ff" opacity="0.9"/>
    <circle cx="0" cy="0" r="8" fill="#FFE66D" opacity="0.9"/>
    <circle cx="0" cy="0" r="4" fill="#ff6B6B" opacity="0.8"/>
  </g>
  
  <!-- Camera specs -->
  <g>
    <text x="20" y="390" font-size="12" fill="#0099ff" font-weight="bold">MAIN SENSOR:</text>
    <text x="20" y="410" font-size="11" fill="#999">200MP f/1.7 Quad-pixel</text>
    
    <text x="20" y="435" font-size="12" fill="#0099ff" font-weight="bold">VIDEO RECORDING:</text>
    <text x="20" y="455" font-size="11" fill="#999">4K @120fps · 8K @60fps</text>
    
    <text x="200" y="435" font-size="12" fill="#0099ff" font-weight="bold">ZOOM:</text>
    <text x="200" y="455" font-size="11" fill="#999">5x Optical · 25x Digital</text>
  </g>
</svg>